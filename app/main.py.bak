@app.post("/parsePdfWithPyPDF")
async def parse_pdf_with_pypdf(
    file: Annotated[UploadFile, File(...)], kb_id: Annotated[str, Form(...)]
):
    if not file.filename:
        raise HTTPException(status_code=400, detail="未选择文件")

    # 生成唯一文件名，避免重名覆盖
    task_id = str(uuid.uuid4())
    save_name = f"{task_id}_{file.filename}"
    save_path = UPLOAD_DIR / save_name

    # 读取上传文件内容
    content = await file.read()

    # 保存到本地
    with open(save_path, "wb") as f:
        f.write(content)

    # 解析PDF内容
    try:
        reader = PdfReader(save_path)
        text_content = ""
        for page in reader.pages:
            if page.extract_text() == None:
                continue
            text_content += page.extract_text() + "\n"
        print(f"解析完成，提取文本长度: {len(text_content)}")
        print(f"提取文本内容示例: {text_content[:500]}")  # 打印前500字符作为示例

        save_to_chromadb(text_content, save_path, kb_id, task_id, file.filename)

    except Exception as e:
        raise HTTPException(status_code=500, detail=f"PDF解析失败: {str(e)}")

    return {
        "task_id": task_id,
        "filename": file.filename,
        "kb_id": kb_id,
        "saved_path": str(save_path),
        "text_content": text_content,
    }


def save_to_chromadb(
    text_content: str, file_path: str, kb_id: str, doc_id: str, file_name: str
):
    collection = client.get_or_create_collection(name="test_collection")
    chunks = split_text(text_content)
    chunk_ids = [f"{doc_id}_{idx}" for idx, _ in enumerate(chunks)]

    collection.add(
        ids=chunk_ids,
        documents=chunks,
        metadatas=[
            {
                "chunk_id": chunk_ids[idx],
                "doc_id": doc_id,
                "kb_id": kb_id,
                "file_name": file_name,
                "page": 0,
                "chunk_index": idx,
            }
            for idx, _ in enumerate(chunks)
        ],
    )

    print(collection.peek())

    results = collection.query(
        query_texts=[
            "章节名称是什么?",
            "沈归是谁?",
        ],
        n_results=5,
    )

    for i, query_result in results.items():
        print(f"\n查询结果:{i}")
        print(query_result)
